# MySQL
DB_NAME=course_management
DB_USER=course_app
DB_PASSWORD=course_app
DB_ROOT_PASSWORD=root
DB_PORT=3306

# Backend
APP_PORT=8080

# Frontend (porta publicada do container; também compõe o FRONTEND_ORIGIN do CORS da API)
FRONTEND_PORT=4200

# JWT (RS256). As chaves ficam em PEM nos resources (par de demo). Aqui só a duração do token.
JWT_DURATION=3600

# Admin inicial (semeado no primeiro boot)
ADMIN_EMAIL=admin@unifor.br
ADMIN_PASSWORD=Ab!12345
