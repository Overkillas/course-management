# MySQL
DB_NAME=course_management
DB_USER=course_app
DB_PASSWORD=course_app
DB_ROOT_PASSWORD=root
DB_PORT=3306

# Backend
APP_PORT=8080

# JWT (HS256). Valor de desenvolvimento/demo, não usado em produção: lá, defina um
# segredo real, longo e aleatório (mínimo 32 caracteres), mantido fora do versionamento.
JWT_SECRET=dev-demo-secret-not-for-production-1234567890
JWT_DURATION=3600

# Admin inicial (semeado no primeiro boot)
ADMIN_EMAIL=admin@unifor.br
ADMIN_PASSWORD=Ab!12345
